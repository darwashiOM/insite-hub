rules_version = '2';

// Proxa Labs CMS — content store.
// Public can read PUBLISHED content only. Writes require an authenticated staff
// session (custom token minted by adminLogin). Two roles: admin (token.admin ==
// true) has full control; editor (token.role == 'editor') can manage CONTENT but
// not design/settings (siteContent). The admin SDK in Cloud Functions bypasses
// these rules, so login-attempt tracking needs no client allowance.
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }
    // Admin OR editor — anyone allowed to manage content.
    function isStaff() {
      return request.auth != null
             && (request.auth.token.admin == true || request.auth.token.role == 'editor');
    }

    match /articles/{id} {
      // get + list. Public list queries must be filtered to published == true;
      // staff may read drafts too.
      allow read: if resource.data.published == true || isStaff();
      allow create, update, delete: if isStaff();
      match /versions/{versionId} {
        allow read, write: if isStaff();
      }
    }

    // CMS-built pages (kit-of-sections) — public reads published ones; staff writes.
    // customCode injects executable script into the page head, so only an ADMIN may
    // set or change it; an editor must leave it empty (create) or unchanged (update).
    match /pages/{id} {
      allow read: if resource.data.published == true || isStaff();
      allow create: if isStaff()
                    && (isAdmin() || !('customCode' in request.resource.data) || request.resource.data.customCode == '');
      allow update: if isStaff()
                    && (isAdmin() || request.resource.data.customCode == resource.data.customCode);
      allow delete: if isStaff();
      match /versions/{versionId} {
        allow read, write: if isStaff();
      }
    }

    // Case studies — public reads published ones; staff reads drafts + writes.
    match /caseStudies/{id} {
      allow read: if resource.data.published == true || isStaff();
      allow create, update, delete: if isStaff();
      match /versions/{versionId} {
        allow read, write: if isStaff();
      }
    }

    // Video library — public reads published ones; staff reads drafts + writes.
    match /videos/{id} {
      allow read: if resource.data.published == true || isStaff();
      allow create, update, delete: if isStaff();
      match /versions/{versionId} {
        allow read, write: if isStaff();
      }
    }

    // Media library — staff-only (the public uses the image URLs directly).
    match /media/{id} {
      allow read, write: if isStaff();
    }

    // Author records — staff-only (their fields are denormalized into published
    // articles, so the public never needs to read this collection directly).
    match /authors/{id} {
      allow read, write: if isStaff();
      match /versions/{versionId} {
        allow read, write: if isStaff();
      }
    }

    // Full form definitions are STAFF-ONLY — they hold server-only fields
    // (notifyEmail, gatedFileUrl). The public renders a form from the stripped
    // formsPublic mirror instead; submitForm (admin SDK) reads this full doc.
    match /forms/{id} {
      allow read, write: if isStaff();
      match /versions/{versionId} {
        allow read, write: if isStaff();
      }
    }

    // Public form-render mirror — safe subset (no notifyEmail / gatedFileUrl).
    match /formsPublic/{id} {
      allow read: if resource.data.published == true || isStaff();
      allow write: if isStaff();
    }

    // Form submissions — staff-only reads; NO client writes (the submitForm Cloud
    // Function writes them via the admin SDK, which bypasses these rules).
    match /formSubmissions/{id} {
      allow read, delete: if isStaff();
      allow create, update: if false;
    }

    // Page content overrides + nav + redirects + per-page SEO = DESIGN/SETTINGS.
    // Publicly readable; ADMIN-only writes (editors can't touch the design).
    match /siteContent/{page} {
      allow read: if true;
      allow write: if isAdmin();
      match /versions/{versionId} {
        allow read, write: if isAdmin();
      }
    }

    // Activity log (who changed what, when). Staff append; only admins read it;
    // never editable/deletable. The create is validated so an editor can't forge
    // the actor, backdate the entry, or add extra fields.
    match /auditLog/{id} {
      allow create: if isStaff()
                    && request.resource.data.actor == (request.auth.token.admin == true ? 'admin' : 'editor')
                    && request.resource.data.at == request.time
                    && request.resource.data.keys().hasOnly(['action', 'collection', 'docId', 'actor', 'at'])
                    && request.resource.data.action is string
                    && request.resource.data.collection is string;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // Custom content-TYPE definitions (the schema a marketer defines). Public read
    // (the generic list/detail pages need the schema to render); admin-only write
    // (defining a type is a structural/settings action).
    match /contentTypes/{id} {
      allow read: if true;
      allow write: if isAdmin();
      match /versions/{versionId} { allow read, write: if isStaff(); }
    }

    // Entries of custom content types. Public reads published; staff (admin/editor)
    // read drafts + write.
    match /content/{id} {
      allow read: if resource.data.published == true || isStaff();
      allow create, update, delete: if isStaff();
      match /versions/{versionId} { allow read, write: if isStaff(); }
    }

    // Everything else (incl. server-only login-attempt records) is denied to clients.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
