rules_version = '2';

// Proxa Labs CMS — content store.
// Public can read PUBLISHED articles only. All writes require an authenticated
// admin session (custom token with claim admin:true, minted by the adminLogin
// Cloud Function after the password check). The admin SDK in Cloud Functions
// bypasses these rules, so login-attempt tracking needs no client allowance.
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    match /articles/{id} {
      // get + list. Public list queries must be filtered to published == true;
      // admins may read drafts too.
      allow read: if resource.data.published == true || isAdmin();
      allow create, update, delete: if isAdmin();

      // Version snapshots — admin only (never exposed to the public).
      match /versions/{versionId} {
        allow read, write: if isAdmin();
      }
    }

    // CMS-built pages (kit-of-sections) — public reads published ones; admin writes.
    match /pages/{id} {
      allow read: if resource.data.published == true || isAdmin();
      allow create, update, delete: if isAdmin();
      match /versions/{versionId} {
        allow read, write: if isAdmin();
      }
    }

    // Case studies — public reads published ones; admin reads drafts + writes.
    match /caseStudies/{id} {
      allow read: if resource.data.published == true || isAdmin();
      allow create, update, delete: if isAdmin();
      match /versions/{versionId} {
        allow read, write: if isAdmin();
      }
    }

    // Video library — public reads published ones; admin reads drafts + writes.
    match /videos/{id} {
      allow read: if resource.data.published == true || isAdmin();
      allow create, update, delete: if isAdmin();
      match /versions/{versionId} {
        allow read, write: if isAdmin();
      }
    }

    // Media library — admin-only (the public uses the image URLs directly, not
    // this catalog of metadata).
    match /media/{id} {
      allow read, write: if isAdmin();
    }

    // Author records — admin-only (their fields are denormalized into published
    // articles, so the public never needs to read this collection directly).
    match /authors/{id} {
      allow read, write: if isAdmin();
      match /versions/{versionId} {
        allow read, write: if isAdmin();
      }
    }

    // Full form definitions are ADMIN-ONLY — they hold server-only fields
    // (notifyEmail, gatedFileUrl). The public renders a form from the stripped
    // formsPublic mirror instead; submitForm (admin SDK) reads this full doc.
    match /forms/{id} {
      allow read, write: if isAdmin();
      match /versions/{versionId} {
        allow read, write: if isAdmin();
      }
    }

    // Public form-render mirror — safe subset (no notifyEmail / gatedFileUrl).
    match /formsPublic/{id} {
      allow read: if resource.data.published == true || isAdmin();
      allow write: if isAdmin();
    }

    // Form submissions — admin-only reads; NO client writes (the submitForm Cloud
    // Function writes them via the admin SDK, which bypasses these rules).
    match /formSubmissions/{id} {
      allow read, delete: if isAdmin();
      allow create, update: if false;
    }

    // Page content overrides (editable marketing copy). Publicly readable; admin-only writes.
    match /siteContent/{page} {
      allow read: if true;
      allow write: if isAdmin();

      match /versions/{versionId} {
        allow read, write: if isAdmin();
      }
    }

    // Everything else (incl. server-only login-attempt records) is denied to clients.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
