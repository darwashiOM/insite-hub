rules_version = '2';

// Proxa Labs CMS — image storage.
// Blog images are publicly readable (they appear on the public site) but only an
// authenticated admin (custom token claim admin:true) may upload/delete.
service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    match /blog/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin()
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
