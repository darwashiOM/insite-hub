rules_version = '2';

// Proxa Labs CMS — image storage.
// Blog images are publicly readable (they appear on the public site) but only an
// authenticated admin (custom token claim admin:true) may upload/delete.
service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    match /blog/{allPaths=**} {
      allow read: if true;
      // create/update require admin + size + raster image type (SVG excluded, it can
      // carry script). On delete request.resource is null, so allow admin deletes too.
      allow write: if isAdmin()
                   && (request.resource == null
                       || (request.resource.size < 10 * 1024 * 1024
                           && request.resource.contentType.matches('image/(png|jpe?g|gif|webp)')));
    }

    // Gated / downloadable files (PDF whitepapers etc.). Admin uploads only, and
    // not publicly listable — served only via the unguessable download-URL token
    // that submitForm hands back after a valid submission, so the gate holds.
    match /files/{allPaths=**} {
      allow read: if false;
      allow write: if isAdmin()
                   && (request.resource == null || request.resource.size < 26 * 1024 * 1024);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
