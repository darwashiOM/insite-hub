# ── InsiteHub Email Configuration ──────────────────────
# Copy this file to functions/.env and fill in your values.
#
# STEP 1: Generate a Gmail App Password
#   1. Go to https://myaccount.google.com/apppasswords
#   2. Sign in to your Google account
#   3. Select "Mail" as the app, "Other" as the device (name it "InsiteHub")
#   4. Copy the 16-character password Google gives you
#
# STEP 2: Fill in the values below
#
# The SMTP account that sends the emails. Use a domain-owned mailbox,
# for example no-reply@insitehub.com or sales@insitehub.com.
SMTP_EMAIL=no-reply@insitehub.com
#
# The app password from Step 1 (NOT your regular password):
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
#
# Public sender shown in recipients' inboxes. With Gmail/Workspace SMTP,
# this must be the SMTP mailbox or a verified send-as alias.
FROM_NAME=InsiteHub Website
FROM_EMAIL=no-reply@insitehub.com
#
# Where inquiry emails are delivered (can be any email address):
NOTIFY_EMAIL=sales@insitehub.com,john.royer@insitehub.com
#
# Innovation Collective event registrations go to Mercy. Defaults in code to
# mehrler@proxalabs.com,mercy@ehrlermarketingadvisory.com; set this to override (comma-separated):
EVENT_NOTIFY_EMAIL=mehrler@proxalabs.com,mercy@ehrlermarketingadvisory.com
#
# ── To change the recipient email ──────────────────────
# Edit NOTIFY_EMAIL above in functions/.env, then redeploy:
#   cd functions && firebase deploy --only functions
#
# ── To add more recipients ─────────────────────────────
# Use comma-separated emails:
#   NOTIFY_EMAIL=person1@company.com,person2@company.com
#
# ── Frontend Function URLs ─────────────────────────────
# After deploying functions, paste the URLs here and in .env:
VITE_CONTACT_FUNCTION_URL=https://submitcontact-<hash>.a.run.app
VITE_NEWSLETTER_FUNCTION_URL=https://submitnewsletter-<hash>.a.run.app
# Only needed if the /api/event-register hosting rewrite isn't used (defaults to /api/event-register):
VITE_EVENT_REGISTER_URL=https://submiteventregistration-<hash>.a.run.app

# ── Google Analytics 4 ─────────────────────────────
# Create a GA4 property (analytics.google.com), copy its Measurement ID.
# Tracking is OFF until this is set, so builds/previews stay clean.
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Site URL + social share image ──────────────────
# Production origin for canonical + sitemap + OG tags. Change when the
# domain flips to proxalabs.com. VITE_OG_IMAGE should be an absolute URL
# to a ~1200x630 share image.
VITE_SITE_URL=https://www.insitehub.com
VITE_OG_IMAGE=

# ── Sentry Frontend Monitoring ─────────────────────
# Public browser DSN from Sentry project settings.
VITE_SENTRY_DSN=https://
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Sentry CI/CD Source Map Upload ─────────────────
# Do not put real values in committed files. Add these as GitHub Actions secrets.
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENTRY_ORG=insitehub
SENTRY_PROJECT=javascript-react
SENTRY_RELEASE=use-git-sha-in-ci
