{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/contact",
        "function": { "functionId": "submitContact", "region": "us-central1" }
      },
      {
        "source": "/api/newsletter",
        "function": { "functionId": "submitNewsletter", "region": "us-central1" }
      },
      {
        "source": "/api/admin-login",
        "function": { "functionId": "adminLogin", "region": "us-central1" }
      },
      {
        "source": "/api/content",
        "function": { "functionId": "getContent", "region": "us-central1" }
      },
      {
        "source": "/api/submit-form",
        "function": { "functionId": "submitForm", "region": "us-central1" }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": {
    "source": "functions"
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": [
    { "bucket": "insite-hub-web-blog", "rules": "storage.rules" }
  ],
  "emulators": {
    "auth": { "port": 9099 },
    "functions": { "port": 5001 },
    "firestore": { "port": 8080 },
    "storage": { "port": 9199 },
    "ui": { "enabled": true },
    "singleProjectMode": true
  }
}
